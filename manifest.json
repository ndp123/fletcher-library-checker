{
  "manifest_version": 3,
  "name": "Fletcher Price Checker",
  "version": "1.0",
  "description": "Check book prices across multiple sites",
  "permissions": ["tabs"],

  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
"action": {
"default_popup": "search.html"
},
"background": {
   "service_worker": "search.js"
}
}
